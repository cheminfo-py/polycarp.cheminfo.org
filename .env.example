# Backend service image
BACKEND_IMAGE=ghcr.io/lamalab-org/copolymer-reactivity:latest

# Cloudflare tunnel (compose.example.cloudflared.yaml only)
CLOUDFLARED_IMAGE=cloudflare/cloudflared:2025.4.2
CLOUDFLARE_TUNNEL_TOKEN=

# Public domain (compose.example.traefik.yaml only)
DOMAIN=polycarp.cheminfo.org

# API base URL used by the React frontend at build time.
# In production (Docker) the nginx reverse proxy serves /api/ → backend:8000,
# so keep the default /api.  For local testing against the live server set:
#   VITE_API_URL=https://polycarp.cheminfo.org/api
VITE_API_URL=/api
